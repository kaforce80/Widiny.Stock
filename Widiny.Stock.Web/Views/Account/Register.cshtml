@model Widiny.Stock.Web.Models.Auth.AdminRegisterViewModel
@{
    ViewData["Title"] = "관리자 등록";
}

<section class="auth-wrap register-wrap">
    <div class="auth-card panel">
        <h2>관리자 등록</h2>
        <p>관리자 정보 입력 후 계정을 생성합니다.</p>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <label asp-for="LoginId">Login ID (Email)</label>
            <input asp-for="LoginId" type="email" autocomplete="username" />
            <span asp-validation-for="LoginId" class="validation"></span>

            <label asp-for="FirstName">First Name</label>
            <input asp-for="FirstName" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="validation"></span>

            <label asp-for="LastName">Last Name</label>
            <input asp-for="LastName" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="validation"></span>

            <label asp-for="PrimaryEmail">Primary Email</label>
            <input asp-for="PrimaryEmail" type="email" autocomplete="email" />
            <span asp-validation-for="PrimaryEmail" class="validation"></span>

            <label asp-for="Password">비밀번호</label>
            <input asp-for="Password" type="password" autocomplete="new-password" />
            <span asp-validation-for="Password" class="validation"></span>

            <button type="submit">등록</button>
        </form>

        <p class="auth-link">이미 계정이 있나요? <a asp-action="Login">로그인으로 이동</a></p>
    </div>
</section>
